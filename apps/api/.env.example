# HOU53-bot API — example environment file.
# Copy to `.env` (gitignored) and edit. Every var is optional; defaults
# work for local development against the artifact under ../../models/.

# --- Artifact ---------------------------------------------------------------
# HOU53_API_MODELS_DIR_NAME=models
# HOU53_API_PIPELINE_FILENAME=hou53-pipeline.joblib
# HOU53_API_METADATA_FILENAME=model_metadata.json

# --- SHAP -------------------------------------------------------------------
# HOU53_API_SHAP_TOP_K=5
# HOU53_API_SHAP_BACKGROUND_SIZE=50

# --- HTTP -------------------------------------------------------------------
# Comma-separated list of origins. Pydantic-settings parses tuples
# from comma-separated env strings.
# HOU53_API_CORS_ALLOW_ORIGINS=http://localhost:3000,https://hou53.example.com

# --- Logging ----------------------------------------------------------------
# HOU53_API_LOG_LEVEL=INFO
# HOU53_API_LOG_FORMAT=console   # 'json' for production

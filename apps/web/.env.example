# Direct OpenAI provider authentication.
OPENAI_API_KEY=

# Auth.js CredentialsProvider demo user.
AUTH_SECRET=
HOU53_AUTH_EMAIL=demo@hou53.local
HOU53_AUTH_PASSWORD_HASH=
HOU53_AUTH_DISPLAY_NAME=Demo User

# Prediction persistence and FastAPI BFF target.
DATABASE_URL=
HOU53_API_BASE_URL=http://localhost:8000
HOU53_API_TIMEOUT_MS=10000

# NLP parser settings.
HOU53_NLP_MODEL=gpt-5.4-mini
HOU53_NLP_TIMEOUT_MS=15000
HOU53_NLP_MAX_INPUT_CHARS=2000
HOU53_NLP_RATE_LIMIT_REQUESTS=20
HOU53_NLP_RATE_LIMIT_WINDOW_MS=60000

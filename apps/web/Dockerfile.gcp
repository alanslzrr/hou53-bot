# syntax=docker/dockerfile:1.10

FROM node:22-bookworm-slim AS base

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV NEXT_TELEMETRY_DISABLED=1
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0

WORKDIR /repo

RUN corepack enable \
    && corepack prepare pnpm@10.30.3 --activate

FROM base AS deps

COPY pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json

RUN pnpm install --frozen-lockfile --filter ./apps/web...

FROM base AS build

COPY --from=deps /repo /repo
COPY apps/web apps/web

ENV NODE_ENV=production
ENV OPENAI_API_KEY=build-placeholder
ENV DATABASE_URL=postgresql://build:build@localhost:5432/build
ENV AUTH_SECRET=build-placeholder
ENV HOU53_AUTH_EMAIL=build@example.com
ENV HOU53_AUTH_PASSWORD_HASH=build-placeholder
ENV HOU53_API_BASE_URL=http://localhost:8000
ENV AUTH_TRUST_HOST=true

RUN pnpm --dir apps/web build

FROM base AS runtime

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /repo

RUN groupadd --gid 1001 app \
    && useradd --uid 1001 --gid app --create-home app

COPY --from=build --chown=app:app /repo /repo

USER app

EXPOSE 8080

CMD ["sh", "-c", "cd apps/web && pnpm start --hostname 0.0.0.0 --port ${PORT:-8080}"]
